{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kaa",
  "patterns": [
    {
      "include": "#variables"
    },
    {
      "include": "#exports"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.kaa"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.kaa",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.kaa"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|else|for|while|return|and|or)\\b",
          "name": "keyword.control.kaa"
        },
        {
          "match": "\\b(add|all)\\b",
          "name": "keyword.control.import.kaa"
        },
        {
          "match": "\\b(fun|class)\\b",
          "name": "storage.type.kaa"
        },
        {
          "match": "\\b(print|input)\\b",
          "name": "support.function.kaa"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "match": "-(i|f|s|l|t|d|py|obj|T|F)\\b",
          "name": "storage.type.modifier.kaa"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false|nil)\\b",
          "name": "constant.language.kaa"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.kaa"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "(>>|->|==|!=|>=|<=|\\+|-|\\*|/|%|>|<|!|=|\\?|:|\\.|\\|)",
          "name": "keyword.operator.kaa"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
          "name": "entity.name.function.kaa"
        }
      ]
    },
    "exports": {
      "patterns": [
        {
          "begin": "\\b(expor)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.kaa"
            }
          },
          "end": ";",
          "patterns": [
            {
              "match": "\\b([a-zA-Z_]\\w*)\\b",
              "name": "entity.name.function.kaa"
            }
          ]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\b(var)\\b(?:\\s+(-(?:i|f|s|l|t|d|py|obj|T|F)\\b))?\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": {
              "name": "entity.name.type.class.kaa"
            },
            "2": {
              "name": "storage.type.modifier.kaa"
            },
            "3": {
              "name": "entity.name.function.kaa"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.kaa"
}
